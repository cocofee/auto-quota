def _get_province_metadata() -> dict[str, object]:
    now = time.time()
    cached = _province_metadata_cache.get("data")
    expires_at = float(_province_metadata_cache.get("expires_at") or 0.0)
    if cached is not None and now < expires_at:
        return cached

    with _province_metadata_lock:
        cached = _province_metadata_cache.get("data")
        expires_at = float(_province_metadata_cache.get("expires_at") or 0.0)
        now = time.time()
        if cached is not None and now < expires_at:
            return cached

        data = _scan_province_metadata()
        _province_metadata_cache["data"] = data
        _province_metadata_cache["expires_at"] = now + _PROVINCE_METADATA_CACHE_TTL
        return data


def _scan_province_metadata() -> dict[str, object]:
    import sqlite3

    groups: dict[str, str] = {}
    subgroups: dict[str, str] = {}

    if QUOTA_DATA_DIR.exists():
        for item in sorted(QUOTA_DATA_DIR.iterdir()):
            if not item.is_dir():
                continue
            has_xlsx = any(item.glob("*.xlsx"))
            if has_xlsx:
                groups[item.name] = item.name[:2]
                continue

            group_name = "鏂扮枂" if item.name.startswith("鏂扮枂-") else item.name
            region = item.name[3:] if item.name.startswith("鏂扮枂-") else ""
            for sub in sorted(item.iterdir()):
                if not sub.is_dir():
                    continue
                groups[sub.name] = group_name
                if region:
                    subgroups[sub.name] = region

    provinces: list[str] = []
    if PROVINCES_DB_DIR.exists():
        for item in sorted(PROVINCES_DB_DIR.iterdir()):
            if not item.is_dir():
                continue
            quota_db = item / "quota.db"
            if not quota_db.exists():
                continue

            try:
                with sqlite3.connect(str(quota_db), timeout=1.0) as conn:
                    row = conn.execute("SELECT 1 FROM quotas LIMIT 1").fetchone()
                if row is None:
                    continue
            except Exception:
                continue

            provinces.append(item.name)
            if item.name not in groups:
                groups[item.name] = item.name[:2]

    return {
        "provinces": provinces,
        "groups": groups,
        "subgroups": subgroups,
    }

