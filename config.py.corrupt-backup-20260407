def get_sibling_provinces(main_province: str) -> list[str]:
    """鏌ユ壘涓庝富瀹氶搴撳悓鐪佷唤銆佸悓骞翠唤鐨勫厔寮熷簱锛堣嚜鍔ㄦ寕杞界敤锛?
    渚嬪锛氳緭鍏?瀹佸瀹夎宸ョ▼璁′环瀹氶(2019)"
    杩斿洖锛歔"瀹佸甯傛斂宸ョ▼璁′环瀹氶(2019)", "瀹佸鎴垮眿寤虹瓚瑁呴グ宸ョ▼璁′环瀹氶(2019)", ...]

    鍒嗙粍瑙勫垯锛氭彁鍙栫渷浠藉悕锛堝墠2-3瀛楋級+ 骞翠唤锛堟嫭鍙蜂腑4浣嶆暟瀛楋級锛屼袱鑰呴兘鐩稿悓鎵嶇畻鍚屾壒銆?
    """
    import re

    def _extract_region_year(name: str):
        """从定额库名提取(省份, 年份)。"""
        year_match = re.search(r'[（(](\d{4})[)）]', name)
        year = year_match.group(1) if year_match else ""
        prefix_match = re.match(
            r'^([\u4e00-\u9fff]{2,8}?)(?:省|市|自治区|特别行政区|回族自治区|壮族自治区|维吾尔自治区)',
            name,
        )
        prefix = prefix_match.group(1) if prefix_match else name[:2]
        region = prefix[:2]
        return region, year

    main_region, main_year = _extract_region_year(main_province)
    if not main_year:
        return []  # 鏃犳硶鎻愬彇骞翠唤锛屼笉鍋氳嚜鍔ㄦ寕杞?
    siblings = []
    for p in list_db_provinces():
        if p == main_province:
            continue  # 璺宠繃鑷繁
        r, y = _extract_region_year(p)
        if r == main_region and y == main_year:
            siblings.append(p)

    return siblings


def _split_keywords(text: str) -> list[str]:
    """灏嗙敤鎴疯緭鍏ユ媶鎴愬叧閿瘝鍒楄〃锛堟寜涓枃/鏁板瓧/瀛楁瘝鐨勮嚜鐒惰竟鐣屾媶鍒嗭級

    鐪佷唤鍚嶉€氬父鐢?鍦板尯(2瀛?+涓撲笟鍏抽敭璇?2瀛?+骞翠唤(4浣?"缁勬垚锛?
    鎸夊瓧绗︾被鍨嬭竟鐣屾媶鍒嗗悗锛屽杩炵画涓枃鍐嶆寜2瀛椾竴缁勭粏鍒嗐€?

    渚嬪:
        "鍖椾含2024"    鈫?["鍖椾含", "2024"]
        "骞夸笢瀹夎"    鈫?["骞夸笢", "瀹夎"]
        "婀栧寳甯傛斂2024" 鈫?["婀栧寳", "甯傛斂", "2024"]
        "淇籍"       鈫?["淇籍"]
    """
    import re
    # 鎸夊瓧绗︾被鍨嬭竟鐣屾媶鍒嗭細杩炵画涓枃銆佽繛缁暟瀛椼€佽繛缁瓧姣嶅悇涓轰竴缁?
    tokens = re.findall(r'[\u4e00-\u9fff]+|[0-9]+|[a-zA-Z]+', text)

    keywords = []
    for token in tokens:
        # 绾腑鏂囦笖瓒呰繃2瀛楋細鎸?瀛椾竴缁勬媶鍒嗭紙"骞夸笢瀹夎" 鈫?"骞夸笢"+"瀹夎"锛?
        if len(token) > 2 and all('\u4e00' <= c <= '\u9fff' for c in token):
            for i in range(0, len(token), 2):
                part = token[i:i+2]
                if len(part) >= 2:
                    keywords.append(part)
        else:
            keywords.append(token)

    return keywords if keywords else [text]


