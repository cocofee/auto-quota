# 环境变量（含API密钥，不上传）
.env

# Python缓存
__pycache__/
*.pyc
*.pyo
.pytest_cache/
pytest-cache-files-*/

# pip install -e . 生成的构建产物
*.egg-info/

# 数据库文件（本地生成，不上传）
db/

# 向量模型缓存
.cache/

# 输出结果
output/

# 日志文件（本地生成，按天轮转）
logs/

# 本地生成的数据文件（经验库/规则/参考数据，机器相关）
data/experience/
data/reference/
data/quota_rules/

# 定额Excel源文件（体积大，各机器不同，不纳入git）
data/quota_data/

# 文档导出（CHM解包等大量生成文件）
docs/chm_dump/

# 调试输出 / 临时文件
tests/debug_sheets.txt
_tmp_*.log
tmp_*.txt

# IDE配置
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db
nul
None/

# Claude Code 本地配置
.claude/

# local temp work dirs
.pytest-tmp/
jarvis-correct-*/
*.tar
*.lpk

# 备份和下载（非项目文件）
backups/
downloads/
