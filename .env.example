# 自动套定额系统 - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥
# 注意：.env 文件不要上传到git

# === 大模型API密钥（至少填一个） ===

# DeepSeek（性价比最高，推荐日常使用）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Claude（准确度最高，复杂匹配使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# OpenAI GPT（备选）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# === 默认使用的模型 ===
# 可选值: deepseek, claude, openai
DEFAULT_LLM=deepseek

# ============================================================
# Web 后端配置（Docker 部署时需要设置以下内容）
# ============================================================

# JWT 认证密钥（生产环境必须设置！）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# PostgreSQL 数据库密码
POSTGRES_PASSWORD=autoquota

# 前端允许访问的域名（多个用逗号分隔）
# CORS_ORIGINS=http://localhost:3000,http://你的域名
