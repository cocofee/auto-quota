# 自动套定额系统 - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥
# 注意：.env 文件不要上传到git

# === 大模型API密钥（至少填一个） ===

# DeepSeek（性价比最高，推荐日常使用）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Claude（准确度最高，复杂匹配使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# OpenAI GPT（备选）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OpenAI 兼容中转地址（如使用中转，例: http://216.173.65.12:8001/codex/v1）
# OPENAI_BASE_URL=http://216.173.65.12:8001/codex/v1

# === 默认使用的模型 ===
# 可选值: deepseek, claude, openai
DEFAULT_LLM=deepseek

# === Reranker 配置 ===
# 可选: cross_encoder, rerankers
# RERANKER_BACKEND: cross_encoder / rerankers / disabled
RERANKER_BACKEND=cross_encoder
# 使用 AnswerDotAI/rerankers 时可指定 model_type，例如 transformer / flashrank
# RERANKERS_MODEL_TYPE=transformer

# === Docker 基础镜像（可选，用于 compose/build 覆盖） ===
# 默认使用官方镜像；如果本机网络拉取慢，可改成你可访问的镜像代理
# PYTHON_IMAGE=python:3.12-slim
# NODE_IMAGE=node:22-alpine
# NGINX_IMAGE=nginx:alpine

# ============================================================
# Web 后端配置（Docker 部署时需要设置以下内容）
# ============================================================

# JWT 认证密钥（生产环境必须设置！）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# PostgreSQL 数据库密码
POSTGRES_PASSWORD=autoquota

# 前端允许访问的域名（多个用逗号分隔）
# CORS_ORIGINS=http://localhost:3000,http://你的域名

# OpenClaw 专用 API Key（用于懒猫微服 OpenClaw 直接调 auto-quota）
OPENCLAW_API_KEY=
# Local match service defaults
LOCAL_MATCH_PORT=9300
# Example: http://your-computer-ip:9300
# LOCAL_MATCH_URL=
# 可选：OpenClaw 服务账号配置
# OPENCLAW_SERVICE_EMAIL=openclaw@system.local
# OPENCLAW_SERVICE_NICKNAME=OpenClaw
# OPENCLAW_SERVICE_QUOTA=1000000

# ============================================================
# 好易支付配置（额度购买功能，可选）
# ============================================================

# 商户ID（在好易支付平台注册后获取）
EPAY_PID=

# 商户密钥（签名用，不能泄露）
EPAY_KEY=

# 好易支付网关地址
EPAY_URL=

# 后端公网地址（支付回调用，好易支付服务器需要能访问到）
EPAY_NOTIFY_BASE_URL=

# 前端地址（支付完成后跳转回来用）
EPAY_RETURN_BASE_URL=
